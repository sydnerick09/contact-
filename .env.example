# ---- Paystack keys ----
# Get these from https://dashboard.paystack.com/#/settings/developers
# The PUBLIC key is safe to expose to the browser. The SECRET key MUST stay
# on the server only — never commit it or put it in front-end code.
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Server ----
PORT=3000

# ---- Pricing / currency ----
# Conversion rate used to display & charge Kenyan numbers in KES (1 USD -> KES).
USD_TO_KES=129
# Premium subscription price (USD) required to unlock non-Kenyan / pro numbers.
PREMIUM_PRICE_USD=2

# ---- Contact ----
SUPPORT_EMAIL=support@numora.example
WHATSAPP_CONTACT=+254700000000
